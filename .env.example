# Copia este archivo como .env y rellena los valores

# Token del bot de Discord (obligatorio)
# Obtenlo en: https://discord.com/developers/applications
DISCORD_TOKEN=tu_token_aqui

# Prefijo de comandos (opcional, default: !)
BOT_PREFIX=!

# IDs de usuarios autorizados separados por coma (opcional)
# Si está vacío, cualquier usuario puede usar el bot
# Cómo obtener tu ID: Activa Modo Desarrollador en Discord
#   → Configuración → Avanzado → Modo Desarrollador
#   → Click derecho en tu usuario → Copiar ID
ALLOWED_USERS=
